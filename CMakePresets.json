{
    "version": 4,
    "configurePresets": [
      {
          "name":  "base",
          "hidden": true,
          "generator":   "Ninja",
          "binaryDir":   "${sourceDir}/build-${presetName}",
          "cacheVariables": {
              "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
              "CMAKE_INSTALL_RPATH": "$ORIGIN:$ORIGIN/.."
          }
      },
      {
          "name": "sycl-base",
          "hidden": true,
          "generator": "Ninja",
          "binaryDir": "${sourceDir}/build-${presetName}",
          "cacheVariables": {
              "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
              "CMAKE_CXX_COMPILER": "clang++",
              "CMAKE_C_COMPILER": "clang",
              "GGML_SYCL": "ON",
              "CMAKE_INSTALL_RPATH": "$ORIGIN:$ORIGIN/.."
          }
      },
      { "name": "debug",   "hidden": true, "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" } },
      { "name": "release", "hidden": true, "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" } },
      { "name": "reldbg",  "hidden": true, "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" } },
      { "name": "static",  "hidden": true, "cacheVariables": { "GGML_STATIC": "ON" } },
  
      {
          "name": "x64-linux-clang-debug",
          "inherits": ["base", "debug"],
          "cacheVariables": {
              "CMAKE_C_COMPILER": "clang",
              "CMAKE_CXX_COMPILER": "clang++"
          }
      },
      {
          "name": "x64-linux-clang-release",
          "inherits": ["base", "release"],
          "cacheVariables": {
              "CMAKE_C_COMPILER": "clang",
              "CMAKE_CXX_COMPILER": "clang++"
          }
      },
      {
          "name": "x64-linux-clang-reldbg",
          "inherits": ["base", "reldbg"],
          "cacheVariables": {
              "CMAKE_C_COMPILER": "clang",
              "CMAKE_CXX_COMPILER": "clang++"
          }
      },
      {
          "name": "x64-linux-clang-static-release",
          "inherits": ["base", "reldbg", "static"],
          "cacheVariables": {
              "CMAKE_C_COMPILER": "clang",
              "CMAKE_CXX_COMPILER": "clang++"
          }
      },
      {
          "name": "x64-linux-sycl-debug",
          "inherits": ["sycl-base", "debug"]
      },
      {
          "name": "x64-linux-sycl-release",
          "inherits": ["sycl-base", "release"]
      }
    ]
  }
  